# OnCallAgent Configuration
# Copy this file to .env and modify as needed

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8819

# Embedder Configuration (Ollama)
EMBEDDER_HOST=ollama
EMBEDDER_PORT=11434
EMBEDDER_MODEL=nomic-embed-text
EMBEDDER_DIMENSION=384

# Qdrant Vector Database Configuration
QDRANT_HOST=qdrant
QDRANT_PORT=6334
QDRANT_COLLECTION=oncallagent

# OpenAI API Configuration
OPENAI_API_KEY=xxxxxx
OPENAI_MODEL=minimax/minimax-m2.1
OPENAI_API_BASE=https://api.qnaigc.com/v1

# Tencent MCP Configuration
TENCENT_MCP_CLS_TYPE=sse
TENCENT_MCP_CLS_URL=https://mcp-api.tencent-cloud.com/sse/xxxxxx

# Prometheus Configuration
# Docker 部署中使用服务名，本地开发使用 localhost
PROMETHEUS_URL=http://prometheus:9090